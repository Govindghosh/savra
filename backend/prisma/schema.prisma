generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  teacher
  student
  admin
}

enum JobStatus {
  queued
  processing
  completed
  failed
  cancelled
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  
  // Profile fields
  name         String?
  age          Int?
  experience   Int?     @map("experience_years")
  proficiency  String?
  qualification String?
  grade        Int?
  subjects     String?
  
  jobs         Job[]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")


  @@index([role])
  @@map("users")
}

model Job {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic        String
  subject      String?
  grade        Int
  slides       Int
  status       JobStatus @default(queued)
  progress     Int       @default(0)
  pptUrl       String?   @map("ppt_url")
  hash         String
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([hash])
  @@index([grade])
  @@index([createdAt])
  @@map("jobs")
}

model PresentationCache {
  id          String   @id @default(cuid())
  embedding   Float[]
  requestHash String   @unique @map("request_hash")
  pptUrl      String   @map("ppt_url")
  metadata    Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("presentation_cache")
}
